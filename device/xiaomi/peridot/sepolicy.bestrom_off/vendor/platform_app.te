allow platform_app app_data_file:file execute;
allow platform_app vendor_file:file { read open getattr map execute watch };

binder_call(platform_app, hal_camera_default)

get_prop(platform_app, vendor_audio_prop)
get_prop(platform_app, vendor_camera_prop)
get_prop(platform_app, vendor_fp_prop)
get_prop(platform_app, vendor_panel_info_prop)

# Camera
allow platform_app app_data_file:file execute;
allow platform_app hal_camera_mivi_hwservice:hwservice_manager find;
allow platform_app app_data_file:file execute;
allow platform_app vendor_audio_prop:file { open read getattr };
allow platform_app vendor_camera_p3enable_prop:file { read map };
allow platform_app vendor_audio_prop:file { getattr };
allow platform_app vendor_displayfeature_prop:file map;
allow platform_app proc_pressure_cpu:file r_file_perms;
allow platform_app proc_pressure_io:file r_file_perms;
allow platform_app proc_pressure_mem:file r_file_perms;

binder_call(platform_app, hal_camera_default)

allow platform_app vendor_hal_camerapostproc_xiaomi_hwservice:hwservice_manager find;
binder_call(platform_app, vendor_hal_camerapostproc_xiaomi)
typeattribute platform_app system_executes_vendor_violators;
allow platform_app vendor_displayfeature_prop:file { read open getattr };
allow platform_app vendor_camera_p3enable_prop:file { read open getattr };

# Fingerprint
allow platform_app vendor_hal_fingerprint_service_xiaomi:service_manager { find };
allow platform_app vendor_file:file { read open getattr map execute watch };
allow platform_app vendor_displayfeature_prop:file read;
allow platform_app vendor_file:file { read open getattr map execute watch };

# we don't have google battery support, add dummy domain and let it return null by selinux denial
dontaudit platform_app hal_dummy_googlebattery_service:service_manager find;

# Allow camera app to access DSP
allow platform_app adsprpcd_file:dir { search getattr };
