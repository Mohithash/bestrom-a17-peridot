<resources>

    <!-- Bottom margin size when fingerprint in display is active -->
    <dimen name="keyguard_indication_margin_bottom">145dp</dimen>

    <!-- Location on the screen of the center of the physical power button. This is a reasonable
    default that should be overridden by device-specific overlays. -->
    <dimen name="physical_power_button_center_screen_location_y">1210px</dimen>

    <!-- Microns/ums (1000 um = 1mm) per pixel for the given device. If unspecified, UI that
         relies on this value will not be sized correctly. -->
    <item name="pixel_pitch" type="dimen" format="float">56.96</item>

    <!-- Status Bar Paddings -->
    <dimen name="status_bar_padding_top">-1dp</dimen>
    <dimen name="status_bar_padding_start">0dp</dimen>
    <dimen name="status_bar_padding_end">0dp</dimen>

    <!-- Status Bar Height -->
    <dimen name="status_bar_height_default">22dp</dimen>
    <dimen name="status_bar_height_landscape">22dp</dimen>
    <dimen name="status_bar_height_portrait">48px</dimen>

    <!-- rounded corner content padding -->
    <dimen name="rounded_corner_content_padding">52.0px</dimen>
    <dimen name="rounded_corner_radius">80.0px</dimen>
    <dimen name="rounded_corner_radius_adjustment">5px</dimen>
    <dimen name="rounded_corner_radius_bottom">106.0px</dimen>
    <dimen name="rounded_corner_radius_bottom_adjustment">4px</dimen>
    <dimen name="rounded_corner_radius_top">80.0px</dimen>
    <dimen name="rounded_corner_radius_top_adjustment">3px</dimen>

</resources>
